command -v ydotool || sudo dnf install ydotool -y
sudo tee /etc/systemd/system/ydotool.service.d/user.conf > /dev/null << EOF
[Service]
ExecStart=
ExecStart=/usr/bin/ydotoold -p /tmp/.ydotool_socket -o $UID:$UID -P 0600
EOF
export YDOTOOL_SOCKET=/tmp/.ydotool_socket >> ~/.bashrc_extra
sudo systemctl enable ydotool
sudo systemctl restart ydotool

xfconf-query -c xfce4-keyboard-shortcuts -p "/commands/custom/<Primary><Alt>Num_Lock" -n -t string -s "xfconf-query -c accessibility -p /MouseKeys -T"
xfconf-query -c xfce4-keyboard-shortcuts -p "/commands/custom/<Super>Down" -n -t string -s "ydotool mousemove --wheel -x 0 -y -1"
xfconf-query -c xfce4-keyboard-shortcuts -p "/commands/custom/<Super>Up" -n -t string -s "ydotool mousemove --wheel -x 0 -y +1"
